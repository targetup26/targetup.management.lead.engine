# Service Configuration
PORT=4001
NODE_ENV=development
INTERNAL_TOKEN=your-secret-internal-token-change-me

# Database (Shared with Core Backend)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=root
DB_NAME=team_attendance

# Redis (Queue) - Laragon Local Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Apify Configuration
APIFY_API_TOKEN=your-apify-token-here
APIFY_ACTOR_ID=compass/crawler-google-places
APIFY_TIMEOUT=300000

# Worker Configuration
WORKER_CONCURRENCY=3
MAX_RETRIES=3
BACKOFF_DELAY=5000
RATE_LIMIT_MAX=10
RATE_LIMIT_DURATION=60000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
